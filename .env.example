# =============================================
# MossGame Environment Configuration
# =============================================

# --- Database (MySQL) ---
DATABASE_URL=mysql://root@localhost:3306/hicyou

# --- Supabase Auth (required for login/OAuth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI Content Generation (optional) ---
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Storage Provider ---
# Choose one: r2 (Cloudflare), qiniu (七牛云), or leave empty for local dev
STORAGE_PROVIDER=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Qiniu Kodo (七牛云) — S3 compatible
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_PUBLIC_URL=
QINIU_ENDPOINT=https://s3.cn-east-1.qiniucs.com

# Storage paths (shared across providers)
STORAGE_UPLOAD_DIR=uploads
STORAGE_LOGO_DIR=logos
STORAGE_COVER_DIR=covers

# --- CAPTCHA ---
# Cloudflare Turnstile (international)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Alibaba Cloud CAPTCHA (阿里云验证码) — domestic
NEXT_PUBLIC_ALIYUN_CAPTCHA_APPKEY=
ALIYUN_CAPTCHA_SECRET=
ALIYUN_CAPTCHA_APPKEY=

# --- Admin ---
ADMIN_EMAILS="admin@example.com"

# --- Cron ---
CRON_SECRET=your_cron_secret

# --- Sponsor (optional) ---
# NEXT_PUBLIC_SPONSOR_IMAGE_URL=
# NEXT_PUBLIC_SPONSOR_LINK=
# NEXT_PUBLIC_SPONSOR_TEXT=
